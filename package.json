{
  "name": "yomitomo",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "turbo dev",
    "dev:app": "pnpm --filter @yomitomo/desktop dev",
    "dev:app:debug": "YOMITOMO_OPEN_DEVTOOLS=1 pnpm --filter @yomitomo/desktop dev",
    "dev:web": "pnpm --filter @yomitomo/web dev",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check",
    "ui:check-primitives": "node scripts/check-ui-primitives.mjs",
    "make": "pnpm run make:app:mac-arm",
    "make:app:mac-arm": "pnpm --filter @yomitomo/desktop make:mac-arm",
    "make:app:win-x64": "pnpm --filter @yomitomo/desktop make:win-x64",
    "deploy:cf": "pnpm --filter @yomitomo/web deploy:cf",
    "deploy:download": "pnpm --filter @yomitomo/download deploy:cf",
    "build": "turbo build",
    "build:app": "pnpm --filter @yomitomo/desktop build",
    "build:web": "pnpm --filter @yomitomo/web build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo test",
    "test:app:e2e": "pnpm --filter @yomitomo/desktop test:e2e"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
