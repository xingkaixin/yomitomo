{
  "name": "@yomitomo/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.95",
    "@ai-sdk/google": "^3.0.90",
    "@ai-sdk/openai": "^3.0.82",
    "@ai-sdk/openai-compatible": "^2.0.58",
    "@yomitomo/core": "workspace:*",
    "@yomitomo/shared": "workspace:*",
    "ai": "^6.0.221",
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
