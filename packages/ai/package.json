{
  "name": "@yomitomo/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@yomitomo/core": "workspace:*",
    "@yomitomo/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
