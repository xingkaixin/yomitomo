{
  "name": "@yomitomo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./article-extraction": "./src/articles/article-extraction.ts",
    "./article-images": "./src/articles/article-images.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@yomitomo/shared": "workspace:*",
    "defuddle": "^0.18.1",
    "dompurify": "^3.4.8",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
