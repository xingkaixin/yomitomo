{
  "name": "@yomitomo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
