{
  "name": "@yomitomo/reader-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./reader-app-view": "./src/shell/reader-app-view.tsx",
    "./reader-agent-annotation-playback": "./src/agent/reader-agent-annotation-playback.ts",
    "./reader-annotations": "./src/annotations/reader-annotations.ts",
    "./reader-animation": "./src/reader-animation.ts",
    "./reader-navigation": "./src/reader-navigation.ts",
    "./reader-reading-sections": "./src/reader-reading-sections.ts",
    "./reader-settings": "./src/reader-settings.ts",
    "./reader-styles": "./src/reader-styles.ts",
    "./reader-theme": "./src/reader-theme.ts",
    "./reader-shortcuts": "./src/reader-shortcuts.ts",
    "./reader-types": "./src/reader-types.ts",
    "./use-agent-annotation-queue": "./src/agent/use-agent-annotation-queue.ts",
    "./use-agent-reading-dock": "./src/agent/use-agent-reading-dock.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@yomitomo/core": "workspace:*",
    "@yomitomo/shared": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
