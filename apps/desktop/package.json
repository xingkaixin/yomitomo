{
  "name": "@yomitomo/desktop",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm run rebuild:native && electron-vite dev --watch",
    "build": "pnpm run rebuild:native && electron-vite build",
    "make:mac-arm": "pnpm run build && electron-builder --config electron-builder.config.cjs --config.directories.output=../../dist/app/mac-arm64 --mac --arm64 --publish never",
    "make:win-x64": "pnpm run build && electron-builder --config electron-builder.config.cjs --config.directories.output=../../dist/app/win-x64 --win --x64 --publish never",
    "db:generate": "drizzle-kit generate",
    "native:install": "pnpm --dir electron-native install",
    "rebuild:native": "pnpm run native:install && node scripts/rebuild-electron-native.mjs && node scripts/prepare-native-macos.mjs",
    "native:verify": "pnpm run rebuild:native && node scripts/verify-native-roots.mjs",
    "test:e2e": "pnpm run build && vitest run --config e2e/vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@embedpdf/engines": "2.14.3",
    "@embedpdf/models": "2.14.3",
    "@embedpdf/pdfium": "2.14.3",
    "@napi-rs/keyring": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.3",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "goey-toast": "^0.5.0",
    "i18next": "^25.7.1",
    "input-otp": "^1.4.2",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "react-i18next": "^16.3.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.1.0",
    "@electron/rebuild": "^4.0.4",
    "@embedpdf/core": "2.14.3",
    "@embedpdf/plugin-bookmark": "2.14.3",
    "@embedpdf/plugin-document-manager": "2.14.3",
    "@embedpdf/plugin-interaction-manager": "2.14.3",
    "@embedpdf/plugin-render": "2.14.3",
    "@embedpdf/plugin-scroll": "2.14.3",
    "@embedpdf/plugin-selection": "2.14.3",
    "@embedpdf/plugin-viewport": "2.14.3",
    "@embedpdf/plugin-zoom": "2.14.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@yomitomo/ai": "workspace:*",
    "@yomitomo/core": "workspace:*",
    "@yomitomo/reader-ui": "workspace:*",
    "@yomitomo/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
