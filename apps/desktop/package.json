{
  "name": "@yomitomo/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm run rebuild:native && electron-vite dev --watch",
    "build": "pnpm run rebuild:native && electron-vite build",
    "make:mac-arm": "pnpm run build && electron-builder --config electron-builder.config.cjs --config.directories.output=../../dist/app/mac-arm64 --mac --arm64",
    "make:win-x64": "pnpm run build && electron-builder --config electron-builder.config.cjs --config.directories.output=../../dist/app/win-x64 --win --x64",
    "db:generate": "drizzle-kit generate",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@yomitomo/ai": "workspace:*",
    "@yomitomo/core": "workspace:*",
    "@yomitomo/reader-ui": "workspace:*",
    "@yomitomo/shared": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.18"
  }
}
