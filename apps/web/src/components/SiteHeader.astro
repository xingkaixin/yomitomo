---
import { changelogsUrl, docsUrl, githubUrl } from '../site-links';
---

<nav class="page-container site-nav" aria-label="主导航">
  <a class="brand-link" href="/" aria-label="Yomitomo 首页">
    <img class="brand-logo" src="/assets/yomitomo-logo.webp" width="32" height="32" alt="" />
    <span class="brand-name">Yomitomo</span>
  </a>
  <div class="header-actions">
    <a class="nav-text-link" href={docsUrl}>文档</a>
    <a class="nav-text-link" href={changelogsUrl}>更新日志</a>
    <a class="header-link" href={githubUrl} target="_blank" rel="noreferrer" aria-label="GitHub">
      <svg class="github-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 0C5.37 0 0 5.5 0 12.3c0 5.42 3.44 10.02 8.2 11.64.6.11.82-.27.82-.59l-.01-2.11c-3.34.74-4.04-1.65-4.04-1.65-.55-1.42-1.33-1.8-1.33-1.8-1.09-.76.08-.74.08-.74 1.2.09 1.84 1.27 1.84 1.27 1.07 1.88 2.81 1.34 3.5 1.02.11-.8.42-1.34.76-1.65-2.66-.31-5.47-1.37-5.47-6.1 0-1.35.47-2.45 1.24-3.31-.13-.31-.54-1.57.12-3.27 0 0 1.01-.33 3.3 1.26A11.2 11.2 0 0 1 12 5.86c1.02 0 2.04.14 3 .41 2.29-1.59 3.3-1.26 3.3-1.26.66 1.7.25 2.96.12 3.27.77.86 1.24 1.96 1.24 3.31 0 4.75-2.81 5.78-5.49 6.09.43.38.81 1.12.81 2.26l-.01 3.35c0 .33.21.71.82.59A12.28 12.28 0 0 0 24 12.3C24 5.5 18.63 0 12 0Z"
        ></path>
      </svg>
    </a>
  </div>
</nav>

<style>
  .page-container {
    box-sizing: border-box;
    width: min(100%, 1120px);
    margin-inline: auto;
    padding-inline: clamp(24px, 5vw, 80px);
  }

  .site-nav {
    display: flex;
    min-height: 64px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-ink, #141414);
    text-decoration: none;
  }

  .brand-logo {
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    mix-blend-mode: multiply;
  }

  .brand-name {
    font-family: var(--font-serif, 'Noto Serif SC', 'Songti SC', Georgia, serif);
    font-size: clamp(15.75px, 0.42vw + 13.65px, 18.9px);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: clamp(12px, 2vw, 20px);
  }

  .nav-text-link {
    color: var(--color-muted, #6b6b6b);
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    font-size: clamp(10.8px, 0.288vw + 9.36px, 12.96px);
    letter-spacing: 0;
    text-decoration: none;
    transition: color 160ms ease;
    white-space: nowrap;
  }

  .nav-text-link:hover {
    color: var(--color-ink, #141414);
  }

  .header-link {
    display: inline-flex;
    width: 38px;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    border: 1px solid hsl(0 0% 8% / 0.12);
    border-radius: 999px;
    background: hsl(0 0% 100% / 0.48);
    color: var(--color-ink, #141414);
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .header-link:hover {
    border-color: hsl(3 62% 42% / 0.34);
    background: hsl(0 0% 100% / 0.78);
    transform: translateY(-1px);
  }

  .github-icon {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
  }

  @media (max-width: 640px) {
    .site-nav {
      min-height: 58px;
      gap: 12px;
    }

    .header-actions {
      gap: 10px;
    }

    .header-link {
      display: none;
    }
  }
</style>
