---
import desktopPackage from '../../../desktop/package.json';
import LandingMasthead from './landing/LandingMasthead.astro';
import HeroSection from './landing/HeroSection.astro';
import MobileProductPreview from './landing/MobileProductPreview.astro';
import DemoSection from './landing/DemoSection.astro';
import StepsSection from './landing/StepsSection.astro';
import AgentsSection from './landing/AgentsSection.astro';
import FeaturesSection from './landing/FeaturesSection.astro';
import FaqSection from './landing/FaqSection.astro';
import DownloadSection from './landing/DownloadSection.astro';
import LandingFooter from './landing/LandingFooter.astro';
import { getFaqItems } from './landing/faq-data';
import { githubUrl, xUrl, youtubeUrl } from '../site-links';
import { buildLandingStructuredData, siteUrl } from '../structured-data';
import '../styles/landing.css';

type Props = {
  lang?: 'zh-CN' | 'en';
};

const { lang = 'zh-CN' } = Astro.props;
const isEnglish = lang === 'en';

const releaseVersion = desktopPackage.version;
const releaseBaseUrl = `https://download.yomitomo.app/releases/download/v${releaseVersion}`;
const downloads = {
  version: releaseVersion,
  mac: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-mac-arm64.dmg`,
  windows: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-win-x64.exe`,
};

const canonicalUrl = isEnglish ? `${siteUrl}/en/` : `${siteUrl}/`;
const alternateUrl = isEnglish ? `${siteUrl}/` : `${siteUrl}/en/`;
const defaultLocaleUrl = `${siteUrl}/`;
const pageTitle = isEnglish
  ? 'Yomitomo - Local-first AI reading companion'
  : 'Yomitomo - 本地优先的 AI 伴读桌面应用';
const pageDescription = isEnglish
  ? 'Yomitomo is a local-first AI reading companion for desktop. Highlight, capture thoughts, discuss with assistants, and keep your reading judgments anchored to the source.'
  : 'Yomitomo 是本地优先的 AI 伴读桌面应用。划线、记下想法、和 AI 助手讨论，把阅读判断留在原文现场。';
const ogImageUrl = `${siteUrl}/assets/og-image.jpg`;
const faqItems = getFaqItems(lang);
const jsonLd = buildLandingStructuredData({
  canonicalUrl,
  description: pageDescription,
  downloads,
  faqItems,
  language: lang,
  sameAs: [githubUrl, xUrl, youtubeUrl],
  title: pageTitle,
  version: releaseVersion,
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={isEnglish ? 'zh-CN' : 'en'} href={alternateUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultLocaleUrl} />
    <link rel="icon" type="image/png" sizes="64x64" href="/assets/favicon.png" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/assets/fonts/SourceSerif4-Bold.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/assets/fonts/JetBrainsMono-Bold.woff2"
      crossorigin
    />
    <noscript>
      <style>
        .reveal {
          opacity: 1;
          transform: none;
        }
      </style>
    </noscript>

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={isEnglish ? 'en_US' : 'zh_CN'} />
    <meta property="og:site_name" content="Yomitomo" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#fbf9f3" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="lp-root">
      <LandingMasthead lang={lang} active="home" />
      <HeroSection lang={lang} version={downloads.version} />
      <MobileProductPreview lang={lang} />
      <DemoSection lang={lang} />
      <div class="reveal"><StepsSection lang={lang} /></div>
      <div class="reveal"><AgentsSection lang={lang} /></div>
      <div class="reveal"><FeaturesSection lang={lang} /></div>
      <div class="reveal"><FaqSection lang={lang} /></div>
      <div class="reveal"><DownloadSection lang={lang} downloads={downloads} /></div>
      <LandingFooter lang={lang} />
    </div>

    <script is:inline>
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        for (const el of reveals) io.observe(el);
      } else {
        for (const el of reveals) el.classList.add('in');
      }
    </script>
  </body>
</html>
