---
import desktopPackage from '../../../desktop/package.json';
import Masthead from './Masthead.astro';
import SiteFooter from './SiteFooter.astro';
import ReaderLanding from './landing/ReaderLanding';
import '../styles/landing.css';

type Props = {
  lang?: 'zh-CN' | 'en';
};

const { lang = 'zh-CN' } = Astro.props;
const isEnglish = lang === 'en';

const releaseVersion = desktopPackage.version;
const releaseBaseUrl = `https://download.yomitomo.app/releases/download/v${releaseVersion}`;
const downloads = {
  version: releaseVersion,
  mac: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-mac-arm64.dmg`,
  windows: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-win-x64.exe`,
};

const siteUrl = 'https://yomitomo.app';
const canonicalUrl = isEnglish ? `${siteUrl}/en/` : `${siteUrl}/`;
const alternateUrl = isEnglish ? `${siteUrl}/` : `${siteUrl}/en/`;
const defaultLocaleUrl = `${siteUrl}/`;
const pageTitle = isEnglish
  ? 'Yomitomo - Local-first AI reading companion'
  : 'Yomitomo - 本地优先的 AI 伴读桌面应用';
const pageDescription = isEnglish
  ? 'Yomitomo is a local-first AI reading companion for desktop. Highlight, capture thoughts, discuss with assistants, and keep your reading judgments anchored to the source.'
  : 'Yomitomo 是本地优先的 AI 伴读桌面应用。划线、记下想法、和 AI 助手讨论，把阅读判断留在原文现场。';
const ogImageUrl = `${siteUrl}/assets/og-image.jpg`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'Yomitomo',
      url: siteUrl,
      inLanguage: lang,
      description: pageDescription,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${siteUrl}/#software`,
      name: 'Yomitomo',
      applicationCategory: 'ProductivityApplication',
      operatingSystem: ['macOS', 'Windows'],
      softwareVersion: releaseVersion,
      url: canonicalUrl,
      image: ogImageUrl,
      description: pageDescription,
      offers: [
        {
          '@type': 'Offer',
          url: downloads.mac,
          price: '0',
          priceCurrency: 'USD',
        },
        {
          '@type': 'Offer',
          url: downloads.windows,
          price: '0',
          priceCurrency: 'USD',
        },
      ],
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={isEnglish ? 'zh-CN' : 'en'} href={alternateUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultLocaleUrl} />
    <link rel="icon" type="image/png" sizes="64x64" href="/assets/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={isEnglish ? 'en_US' : 'zh_CN'} />
    <meta property="og:site_name" content="Yomitomo" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#fbf9f3" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body style="background:#fbf9f3">
    <Masthead lang={lang} active="home" />
    <ReaderLanding lang={lang} downloads={downloads} client:idle />
    <SiteFooter lang={lang} />
  </body>
</html>
