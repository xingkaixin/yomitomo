---
export type ProductCarouselSlide = {
  title: string;
  caption: string;
  image: string;
  alt: string;
};

type Props = {
  slides: ProductCarouselSlide[];
};

const { slides } = Astro.props;
const loopedSlides = [...slides, ...slides, ...slides];
const initialSlidePosition = slides.length;
---

{
  slides.length > 0 ? (
    <section class="product-carousel" aria-label="产品介绍图" data-product-carousel>
      <div class="product-carousel-viewport" data-carousel-viewport>
        {loopedSlides.map((slide, position) => {
          const index = position % slides.length;
          const isInitial = position === initialSlidePosition;

          return (
          <figure
            class:list={['product-carousel-card', isInitial && 'is-active']}
            aria-label={`查看${slide.title}`}
            aria-pressed={isInitial}
            data-carousel-card
            data-carousel-index={index}
            data-carousel-position={position}
            role="button"
            tabindex="0"
          >
            <img
              class="product-carousel-image"
              src={slide.image}
              sizes="(max-width: 640px) 82vw, min(780px, 78vw)"
              alt={slide.alt}
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding={index === 0 ? 'sync' : 'async'}
              draggable="false"
            />
            <figcaption class="product-carousel-copy">
              <span>{slide.title}</span>
              <p>{slide.caption}</p>
            </figcaption>
          </figure>
          );
        })}
      </div>
      <div class="product-carousel-indicators">
        {slides.map((slide, index) => (
          <button
            class:list={['product-carousel-indicator', index === 0 && 'is-active']}
            type="button"
            aria-label={`查看${slide.title}`}
            aria-pressed={index === 0}
            data-carousel-index={index}
          />
        ))}
      </div>
    </section>
  ) : null
}

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-product-carousel]');

  for (const carousel of carousels) {
    const viewport = carousel.querySelector<HTMLElement>('[data-carousel-viewport]');
    const cards = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-card]'));
    const buttons = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>('.product-carousel-indicator'),
    );
    const slideCount = buttons.length;
    let activeIndex = 0;
    let activePosition = slideCount;
    let dragStartX = 0;
    let dragStartScrollLeft = 0;
    let dragDistance = 0;
    let isDragging = false;
    let scrollFrame = 0;
    let normalizeFrame = 0;

    if (!viewport || cards.length === 0 || slideCount === 0) continue;
    const scrollViewport = viewport;

    function normalizeIndex(index: number) {
      return ((index % slideCount) + slideCount) % slideCount;
    }

    function updateActiveSlide(position: number) {
      const index = normalizeIndex(position);
      activeIndex = index;
      activePosition = position;
      for (const [cardIndex, card] of cards.entries()) {
        const active = cardIndex === activePosition;
        card.classList.toggle('is-active', active);
        card.setAttribute('aria-pressed', String(active));
      }
      for (const [buttonIndex, button] of buttons.entries()) {
        const active = buttonIndex === activeIndex;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      }
    }

    function getCenteredSlidePosition() {
      const viewportRect = scrollViewport.getBoundingClientRect();
      const viewportCenter = viewportRect.left + viewportRect.width / 2;
      let closestPosition = activePosition;
      let closestDistance = Number.POSITIVE_INFINITY;

      for (const [position, card] of cards.entries()) {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;
        const distance = Math.abs(cardCenter - viewportCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestPosition = position;
        }
      }

      return closestPosition;
    }

    function canonicalPosition(position: number) {
      return slideCount + normalizeIndex(position);
    }

    function normalizeLoopPosition() {
      if (isDragging) return;
      const normalizedPosition = canonicalPosition(activePosition);
      if (normalizedPosition === activePosition) return;
      cards[normalizedPosition]?.scrollIntoView({
        behavior: 'auto',
        block: 'nearest',
        inline: 'center',
      });
      updateActiveSlide(normalizedPosition);
    }

    function queueLoopNormalization() {
      window.clearTimeout(normalizeFrame);
      normalizeFrame = window.setTimeout(normalizeLoopPosition, 420);
    }

    function findCenteredSlide() {
      const closestPosition = getCenteredSlidePosition();
      if (closestPosition !== activePosition) updateActiveSlide(closestPosition);
      queueLoopNormalization();
    }

    function queueActiveSlideUpdate() {
      window.cancelAnimationFrame(scrollFrame);
      scrollFrame = window.requestAnimationFrame(findCenteredSlide);
    }

    function scrollToPosition(position: number, behavior: ScrollBehavior = 'smooth') {
      cards[position]?.scrollIntoView({
        behavior,
        block: 'nearest',
        inline: 'center',
      });
      updateActiveSlide(position);
      queueLoopNormalization();
    }

    function nearestPositionForIndex(index: number) {
      const normalizedIndex = normalizeIndex(index);
      const candidates = [
        normalizedIndex,
        normalizedIndex + slideCount,
        normalizedIndex + slideCount * 2,
      ];

      return candidates.reduce((nearest, candidate) =>
        Math.abs(candidate - activePosition) < Math.abs(nearest - activePosition)
          ? candidate
          : nearest,
      );
    }

    function scrollToSlide(index: number) {
      scrollToPosition(nearestPositionForIndex(index));
    }

    scrollToPosition(activePosition, 'auto');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const index = Number(button.dataset.carouselIndex);
        if (Number.isInteger(index)) scrollToSlide(index);
      });
    });

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        if (dragDistance > 6) return;
        const position = Number(card.dataset.carouselPosition);
        if (Number.isInteger(position)) scrollToPosition(position);
      });
      card.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        const position = Number(card.dataset.carouselPosition);
        if (Number.isInteger(position)) scrollToPosition(position);
      });
    });

    scrollViewport.addEventListener('scroll', queueActiveSlideUpdate, { passive: true });
    scrollViewport.addEventListener('pointerdown', (event) => {
      if (event.button !== 0) return;
      isDragging = true;
      dragStartX = event.clientX;
      dragDistance = 0;
      dragStartScrollLeft = scrollViewport.scrollLeft;
      scrollViewport.classList.add('is-dragging');
      scrollViewport.setPointerCapture(event.pointerId);
    });
    scrollViewport.addEventListener('pointermove', (event) => {
      if (!isDragging) return;
      dragDistance = Math.abs(event.clientX - dragStartX);
      scrollViewport.scrollLeft = dragStartScrollLeft - (event.clientX - dragStartX);
    });
    scrollViewport.addEventListener('pointerup', (event) => {
      isDragging = false;
      scrollViewport.classList.remove('is-dragging');
      scrollViewport.releasePointerCapture(event.pointerId);
      if (dragDistance <= 6) {
        const targetCard = document
          .elementFromPoint(event.clientX, event.clientY)
          ?.closest<HTMLElement>('[data-carousel-card]');
        const position = Number(targetCard?.dataset.carouselPosition);
        if (Number.isInteger(position)) {
          scrollToPosition(position);
          return;
        }
      }
      scrollToPosition(getCenteredSlidePosition());
    });
    scrollViewport.addEventListener('pointercancel', () => {
      isDragging = false;
      scrollViewport.classList.remove('is-dragging');
      scrollToPosition(getCenteredSlidePosition());
    });
  }
</script>
