---
import { githubUrl, xUrl, youtubeUrl } from '../site-links';
---

<footer class="site-footer">
  <div class="page-container footer-inner">
    <p class="footer-copy">© MIT 2026 Yomitomo</p>
    <nav class="footer-links" aria-label="页脚链接">
      <a href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      <a href={xUrl} target="_blank" rel="noreferrer">X</a>
      <a href={youtubeUrl} target="_blank" rel="noreferrer">YouTube</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-line, #d8d2cc);
    padding-block: 30px;
  }

  .page-container {
    box-sizing: border-box;
    width: min(100%, 1120px);
    margin-inline: auto;
    padding-inline: clamp(24px, 5vw, 80px);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .footer-copy {
    margin: 0;
    color: var(--color-muted, #6b6b6b);
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    font-size: clamp(11.25px, 0.3vw + 9.75px, 13.5px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.5;
    white-space: nowrap;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: var(--font-mono, ui-monospace, Menlo, monospace);
    font-size: clamp(11.25px, 0.3vw + 9.75px, 13.5px);
  }

  .footer-links a {
    position: relative;
    color: var(--color-muted, #6b6b6b);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .footer-links a + a::before {
    position: absolute;
    top: 50%;
    left: -9px;
    width: 1px;
    height: 12px;
    background: hsl(0 0% 8% / 0.18);
    content: '';
    transform: translateY(-50%);
  }

  .footer-links a:hover {
    color: var(--color-ink, #141414);
  }

  @media (max-width: 640px) {
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
