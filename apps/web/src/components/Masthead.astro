---
import { changelogsUrl, englishChangelogsUrl, githubUrl } from '../site-links';

type Props = {
  lang?: 'zh-CN' | 'en';
  active?: 'home' | 'docs' | 'blog' | 'changelogs';
};

const { lang = 'zh-CN', active } = Astro.props;
const isEnglish = lang === 'en';

const homeUrl = isEnglish ? '/en/' : '/';
const alternateUrl = isEnglish ? '/' : '/en/';
const prefix = isEnglish ? '/en' : '';

const navLinks = [
  { key: 'home', label: isEnglish ? 'Home' : '首页', href: homeUrl },
  { key: 'docs', label: isEnglish ? 'Docs' : '文档', href: `${prefix}/docs/` },
  { key: 'blog', label: isEnglish ? 'Blog' : '博客', href: `${prefix}/blog/` },
  {
    key: 'changelogs',
    label: isEnglish ? 'Release Notes' : '更新日志',
    href: isEnglish ? englishChangelogsUrl : changelogsUrl,
  },
] as const;

const languageLabel = isEnglish ? '中' : 'EN';
const pronounceLabel = isEnglish ? 'Play name pronunciation' : '播放产品名发音';
---

<header class="app-masthead">
  <div class="app-masthead-title">
    <h1>Yomitomo</h1>
    <button
      class="app-masthead-phonetic"
      type="button"
      aria-label={pronounceLabel}
      data-brand-pronounce
    >
      /joːmitomo/
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
      </svg>
    </button>
  </div>
  <time class="app-masthead-date" data-masthead-date></time>
</header>

<nav class="app-section-nav" aria-label={isEnglish ? 'Main navigation' : '主导航'}>
  {
    navLinks.map((link) => (
      <a
        class:list={['settings-nav-item', active === link.key && 'is-active']}
        href={link.href}
      >
        <span>{link.label}</span>
      </a>
    ))
  }
  <a class="app-nav-language" href={alternateUrl} aria-label={isEnglish ? 'Switch to Chinese' : 'Switch to English'}>
    {languageLabel}
  </a>
  <a
    class="app-nav-action-button"
    data-tooltip="GitHub"
    href={githubUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="GitHub"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.12-.31-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z"
      ></path>
    </svg>
  </a>
</nav>

<script is:inline define:vars={{ locale: lang }}>
  const dateEl = document.querySelector('[data-masthead-date]');
  if (dateEl) {
    dateEl.textContent = new Intl.DateTimeFormat(locale, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'long',
    }).format(new Date());
  }

  let audio = null;
  let pronunciationPlaying = false;
  for (const pronounceEl of document.querySelectorAll('[data-brand-pronounce]')) {
    pronounceEl.addEventListener('click', () => {
      audio ??= new Audio('/assets/yomitomo.m4a');
      if (pronunciationPlaying) return;
      pronunciationPlaying = true;
      const clearPlaying = () => {
        pronunciationPlaying = false;
      };
      audio.addEventListener('ended', clearPlaying, { once: true });
      audio.addEventListener('pause', clearPlaying, { once: true });
      audio.currentTime = 0;
      try {
        const playResult = audio.play();
        if (playResult instanceof Promise) {
          void playResult.catch(clearPlaying);
        }
      } catch {
        clearPlaying();
      }
    });
  }
</script>

<style>
  @font-face {
    font-family: 'Fraunces';
    src: url('/assets/fonts/Fraunces-VariableFont.ttf') format('truetype');
    font-display: swap;
    font-style: normal;
    font-weight: 100 900;
  }

  .app-masthead {
    position: relative;
    display: grid;
    grid-template-columns: minmax(120px, 1fr) auto minmax(120px, 1fr);
    align-items: start;
    gap: 28px;
    min-height: 148px;
    border-bottom: 1px solid #2a2218;
    background: #fffdf8;
    padding: 22px 34px 18px;
  }

  .app-masthead-title {
    display: grid;
    grid-column: 2;
    justify-items: center;
    gap: 6px;
    padding-top: 2px;
    text-align: center;
  }

  .app-masthead-title h1 {
    margin: 0;
    cursor: default;
    user-select: none;
    color: #2a2218;
    font-family: 'Fraunces', 'Noto Serif SC', 'Songti SC', 'STSong', Georgia, serif;
    font-size: clamp(44px, 6vw, 88px);
    font-variation-settings:
      'SOFT' 80,
      'WONK' 0,
      'opsz' 72;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.92;
  }

  .app-masthead-phonetic {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border: 0;
    background: transparent;
    color: #7a6e5f;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 0;
    cursor: pointer;
    transition: color 0.14s ease;
  }

  .app-masthead-phonetic svg {
    opacity: 0;
    transition: opacity 0.14s ease;
  }

  .app-masthead-phonetic:hover,
  .app-masthead-phonetic:focus-visible {
    color: #a43f37;
  }

  .app-masthead-phonetic:hover svg,
  .app-masthead-phonetic:focus-visible svg {
    opacity: 1;
  }

  .app-masthead-date {
    grid-column: 3;
    justify-self: end;
    color: #7a6e5f;
    font-size: 12px;
    font-weight: 820;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
    padding-top: 4px;
  }

  .app-section-nav {
    display: flex;
    align-items: center;
    gap: 32px;
    min-height: 52px;
    border-bottom: 4px double #2a2218;
    background: #fffdf8;
    padding: 0 34px;
  }

  .settings-nav-item {
    position: relative;
    display: inline-flex;
    height: 52px;
    align-items: center;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: #2a2218;
    font-family: 'Noto Serif SC', 'Songti SC', 'STSong', Georgia, serif;
    font-size: 18px;
    font-weight: 760;
    padding: 0;
    text-decoration: none;
    white-space: nowrap;
    flex: 0 0 auto;
    cursor: pointer;
    transition: color 0.14s ease;
  }

  .settings-nav-item::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: #a43f37;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.18s ease;
  }

  .settings-nav-item:hover {
    color: #a43f37;
  }

  .settings-nav-item:hover::before {
    transform: scaleX(0.36);
  }

  .settings-nav-item.is-active {
    color: #a43f37;
  }

  .settings-nav-item.is-active::before {
    transform: scaleX(1);
  }

  .app-nav-language {
    display: inline-flex;
    min-width: 40px;
    min-height: 32px;
    margin-left: auto;
    align-items: center;
    justify-content: center;
    border: 1px solid #e8e0d4;
    border-radius: 999px;
    background: #fffdfa;
    color: #2a2218;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace;
    font-size: 0.72rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      border-color 150ms ease,
      transform 150ms ease;
  }

  .app-nav-language:hover {
    border-color: rgba(164, 63, 55, 0.42);
    transform: translateY(-1px);
  }

  .app-nav-action-button {
    position: relative;
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    color: #2a2218;
    padding: 0;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }

  .app-nav-action-button:hover,
  .app-nav-action-button:focus-visible {
    background-color: rgba(42, 34, 24, 0.04);
    box-shadow:
      0 0 0 1px rgba(42, 34, 24, 0.16),
      0 9px 20px rgba(42, 34, 24, 0.1);
    outline: 0;
  }

  .app-nav-action-button:active {
    transform: scale(0.96);
  }

  .app-nav-action-button::after {
    position: absolute;
    top: 50%;
    right: calc(100% + 10px);
    z-index: 2;
    opacity: 0;
    border-radius: 999px;
    background: #2a2218;
    box-shadow: 0 8px 18px rgba(42, 34, 24, 0.14);
    color: #fffaf0;
    content: attr(data-tooltip);
    font-size: 12px;
    font-weight: 760;
    line-height: 1;
    padding: 7px 10px;
    pointer-events: none;
    transform: translate(4px, -50%);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
    white-space: nowrap;
  }

  .app-nav-action-button:hover::after,
  .app-nav-action-button:focus-visible::after {
    opacity: 1;
    transform: translate(0, -50%);
  }

  @media (max-width: 760px) {
    .app-masthead {
      grid-template-columns: minmax(0, 1fr) auto;
      min-height: 116px;
      padding: 18px 18px 16px;
    }

    .app-masthead-title {
      grid-column: 1;
      justify-items: start;
      text-align: left;
    }

    .app-masthead-title h1 {
      font-size: 42px;
    }

    .app-masthead-date {
      display: none;
    }

    .app-section-nav {
      gap: 22px;
      overflow-x: auto;
      padding: 0 18px;
    }

    .app-nav-action-button {
      flex: 0 0 auto;
    }
  }
</style>
