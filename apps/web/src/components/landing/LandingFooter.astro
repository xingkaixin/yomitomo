---
import {
  changelogsUrl,
  englishChangelogsUrl,
  githubUrl,
  xUrl,
  youtubeUrl,
} from '../../site-links';

type Props = {
  lang?: 'zh-CN' | 'en';
};

const { lang = 'zh-CN' } = Astro.props;
const isEnglish = lang === 'en';
const prefix = isEnglish ? '/en' : '';
const year = new Date().getFullYear();

const links = [
  { label: isEnglish ? 'Docs' : '文档', href: `${prefix}/docs/` },
  { label: isEnglish ? 'Blog' : '博客', href: `${prefix}/blog/` },
  {
    label: isEnglish ? 'Release Notes' : '更新日志',
    href: isEnglish ? englishChangelogsUrl : changelogsUrl,
  },
];

const fine = isEnglish
  ? `© ${year} YOMITOMO · Open source under the MIT license · Local-first AI reading companion`
  : `© ${year} YOMITOMO · 开源在 MIT 协议下 · 本地优先的 AI 伴读桌面应用`;
---

<footer class="lp-footer">
  <div class="lp-container">
    <div class="row">
      <a class="brand" href={isEnglish ? '/en/' : '/'}>
        Yomitomo
      </a>
      <div class="links">
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
        <span class="social-sep"></span>
        <a class="social" href={githubUrl} target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.61 8.21 11.17.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.37-1.33-1.74-1.33-1.74-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.21 1.84 1.21 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.35 1.24-3.18-.12-.3-.54-1.51.12-3.15 0 0 1.01-.32 3.3 1.21a11.6 11.6 0 0 1 3-.4c1.02 0 2.05.13 3 .4 2.29-1.53 3.3-1.21 3.3-1.21.66 1.64.24 2.85.12 3.15.77.83 1.24 1.89 1.24 3.18 0 4.54-2.81 5.54-5.49 5.83.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .31.21.68.83.56A12.02 12.02 0 0 0 24 12.29C24 5.78 18.63.5 12 .5z"
            ></path>
          </svg>
        </a>
        <a class="social" href={xUrl} target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
        <a class="social" href={youtubeUrl} target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
    <p class="fine">{fine}</p>
  </div>
</footer>
