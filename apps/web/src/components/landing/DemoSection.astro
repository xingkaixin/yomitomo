---
import ReaderDemo from './ReaderDemo';

type Props = {
  lang?: 'zh-CN' | 'en';
};

const { lang = 'zh-CN' } = Astro.props;
const isEnglish = lang === 'en';

const copy = isEnglish
  ? {
      kicker: 'See how it works',
      titlePre: 'One article—',
      titleAnchor: 'lines',
      titlePost: ', notes and discussion all on the page itself.',
      hint: 'Click a line in the text, or "Open discussion"',
    }
  : {
      kicker: '看看它怎么工作',
      titlePre: '一篇文章，',
      titleAnchor: '划线',
      titlePost: '、批注、讨论都在原文现场。',
      hint: '点击文中的划线，或「进入讨论区」',
    };
---

<section class="demo-section">
  <div class="lp-container">
    <div class="demo-head">
      <div>
        <p class="sec-kicker">{copy.kicker}</p>
        <h2 class="sec-title">{copy.titlePre}<span class="demo-line-anchor">{copy.titleAnchor}</span>{
            copy.titlePost
          }</h2>
      </div>
      <span class="hint"><span class="dot"></span>{copy.hint}</span>
    </div>
    <div class="demo-frame reveal">
      <ReaderDemo lang={lang} client:visible />
    </div>
  </div>
</section>
