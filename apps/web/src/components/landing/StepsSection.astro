---
type Props = {
  lang?: 'zh-CN' | 'en';
};

const { lang = 'zh-CN' } = Astro.props;
const isEnglish = lang === 'en';

const copy = isEnglish
  ? {
      kicker: 'What it is',
      title: 'Yomitomo shrinks the smallest unit of reading from the article to the judgment.',
      lead: [
        'Most tools only let you "save" articles. None help you think them through.',
        'Yomitomo flips it: save less, turn what you read into judgments of your own.',
      ],
      steps: [
        [
          'Line',
          "Draw a line where a paragraph makes you pause. It's not a highlight, it's an evidence anchor—precise to the sentence, always traceable back to the source.",
        ],
        [
          'Thought',
          'Write a judgment or question under the line, or invite an AI companion to join. One line can carry many thoughts, growing over time.',
        ],
        [
          'Distill',
          'When the discussion is rich enough, distill it into a conclusion worth keeping—carrying its source and your angle.',
        ],
      ],
    }
  : {
      kicker: '这是什么',
      title: 'Yomitomo 把阅读的最小单位，从文章变成判断。',
      lead: [
        '大多数工具只让你把文章「存起来」，却没人帮你「想清楚」。',
        'Yomitomo 反过来：少存一点，但把读过的真正变成你的判断。',
      ],
      steps: [
        ['划线', '在让你停下来的段落划一条线。它不是高亮，是证据锚点——精确到句子，永远能回到原文。'],
        ['想法', '在划线下方写下判断、追问，或让 AI 伴读加入讨论。一条线可以挂多个想法，持续生长。'],
        ['沉淀', '当讨论足够丰富，把它整理成一段可保留的沉淀。它带着出处，也带着你的角度。'],
      ],
    };

const titleLines = isEnglish
  ? null
  : ['Yomitomo 把阅读的最小单位，', '从文章变成判断。'];
---

<section class="section">
  <div class="lp-container concept-layout">
    <div class="section-copy">
      <p class="sec-kicker">{copy.kicker}</p>
      <h2 class="sec-title">
        {
          titleLines
            ? titleLines.map((line) => <span class="concept-title-line">{line}</span>)
            : copy.title
        }
      </h2>
      <p class="sec-lead">{copy.lead[0]} {copy.lead[1]}</p>
    </div>
    <div class="steps">
      {
        copy.steps.map(([title, desc]) => (
          <article class="step">
            <span class="step-anchor" aria-hidden="true"></span>
            <div class="step-copy">
              <h3>{title}</h3>
              <p>{desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
