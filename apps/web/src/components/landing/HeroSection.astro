---
type Props = {
  lang?: 'zh-CN' | 'en';
  version: string;
};

const { lang = 'zh-CN', version } = Astro.props;
const isEnglish = lang === 'en';

const copy = isEnglish
  ? {
      eyebrow: '500 SAVED · FEW KEPT',
      headPre: 'Shrink reading from the article to the',
      headEm: 'call',
      headTail: '.',
      subLines: [
        'Yomitomo is a local-first AI reading companion.',
        'Highlights are your evidence. Calls are your output.',
      ],
      cta: 'Download Yomitomo',
      altMac: 'Also on macOS →',
      altWin: 'Also on Windows →',
      version: `v${version} · Free & open source · Reading data stays local`,
    }
  : {
      eyebrow: '收藏了 500 篇文章 · 真正留下来的判断有几个',
      headPre: '把阅读的最小单位，从文章变成',
      headEm: '判断',
      headTail: '。',
      subLines: [
        'Yomitomo 是本地优先的 AI 伴读桌面应用',
        '划线是证据锚点，想法是阅读产出。',
      ],
      cta: '下载 Yomitomo',
      altMac: '也支持 macOS →',
      altWin: '也支持 Windows →',
      version: `v${version} · 免费开源 · 阅读数据保存在本地`,
    };
---

<section class="hero-c">
  <div class="lp-container hero-c-inner">
    <p class="hero-c-eyebrow">{copy.eyebrow}</p>
    <h1 class="hero-c-title">{copy.headPre}{isEnglish ? ' ' : ''}<em class="hand-ul">{copy.headEm}<svg class="hand-ul-svg" viewBox="0 0 170 26" preserveAspectRatio="none" aria-hidden="true"><path d="M5 16 C 34 7, 58 21, 86 13 S 138 6, 165 15"></path></svg></em>{copy.headTail}</h1>
    <p class="hero-c-sub">
      {copy.subLines[0]}<br />{copy.subLines[1]}
    </p>
    <div class="hero-c-cta">
      <a class="btn-primary" href="#download">
        <svg class="mark-apple" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M16.7 12.7c0-2.7 2.2-4 2.3-4.1-1.2-1.8-3.2-2.1-3.9-2.1-1.7-.2-3.2 1-4.1 1-.8 0-2.1-1-3.5-1-1.8 0-3.5 1.1-4.4 2.7-1.9 3.4-.5 8.4 1.4 11.1.9 1.3 2 2.8 3.5 2.8 1.4-.1 1.9-.9 3.5-.9s2.1.9 3.6.9c1.5 0 2.4-1.4 3.3-2.7 1-1.5 1.5-3 1.5-3.1 0-.1-3.1-1.3-3.2-4.6ZM14 4.7c.8-1 1.3-2.3 1.1-3.7-1.1 0-2.5.8-3.3 1.7-.7.9-1.3 2.2-1.2 3.5 1.3.1 2.6-.6 3.4-1.5Z"
          ></path>
        </svg>
        <svg class="mark-win" viewBox="0 0 24 24" aria-hidden="true" style="display:none">
          <path
            fill="currentColor"
            d="M1.8 4.2 10.8 3v8.5h-9V4.2Zm10.4-1.4 10-1.4v10.1h-10V2.8ZM1.8 12.5h9V21l-9-1.2v-7.3Zm10.4 0h10v10.1l-10-1.4v-8.7Z"
          ></path>
        </svg>
        {copy.cta}
      </a>
      <div class="cta-alt">
        <a href="#download" data-alt-mac={copy.altMac} data-alt-win={copy.altWin}>{copy.altWin}</a>
        <span class="v">{copy.version}</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const isWin =
    /Win/i.test(navigator.userAgentData?.platform || navigator.platform || '') ||
    /Windows/i.test(navigator.userAgent || '');
  // The primary button targets the detected platform; the alt link points to
  // the *other* one. So on macOS the alt reads "also on Windows", and vice versa.
  for (const el of document.querySelectorAll('.btn-primary .mark-apple')) {
    el.style.display = isWin ? 'none' : '';
  }
  for (const el of document.querySelectorAll('.btn-primary .mark-win')) {
    el.style.display = isWin ? '' : 'none';
  }
  for (const el of document.querySelectorAll('[data-alt-mac][data-alt-win]')) {
    el.textContent = isWin ? el.dataset.altMac : el.dataset.altWin;
  }
</script>
