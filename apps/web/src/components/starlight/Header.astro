---
import LandingMasthead from '../landing/LandingMasthead.astro';
import '../../styles/landing.css';

const path = Astro.url.pathname;
const lang = path.startsWith('/en/') ? 'en' : 'zh-CN';
const normalized = path.replace(/^\/en/, '');
const active = normalized.startsWith('/blog')
  ? 'blog'
  : normalized.startsWith('/changelogs')
    ? 'changelogs'
    : normalized.startsWith('/docs')
      ? 'docs'
      : undefined;
---

<LandingMasthead lang={lang} active={active} />
