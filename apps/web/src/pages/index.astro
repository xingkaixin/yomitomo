---
import desktopPackage from '../../../desktop/package.json';
import ProductCarousel, { type ProductCarouselSlide } from '../components/ProductCarousel.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { githubUrl, youtubeUrl } from '../site-links';
import '../styles/global.css';

const siteUrl = 'https://yomitomo.app';
const canonicalUrl = `${siteUrl}/`;
const pageTitle = 'Yomitomo - 本地优先的 AI 伴读桌面应用';
const pageDescription =
  'Yomitomo 是本地优先的 AI 伴读桌面应用，支持网页文章和 EPUB 阅读，用划线、想法、评论和阅读助手沉淀阅读判断。';
const releaseVersion = desktopPackage.version;
const releaseTag = `v${releaseVersion}`;
const releaseBaseUrl = `https://download.yomitomo.app/releases/download/${releaseTag}`;
const ogImageUrl = `${siteUrl}/assets/og-image.jpg`;
const downloadPlatforms = [
  {
    platform: 'mac',
    name: 'macOS',
    options: [
      {
        label: 'Apple Silicon',
        extension: '.dmg',
        href: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-mac-arm64.dmg`,
      },
    ],
  },
  {
    platform: 'windows',
    name: 'Windows',
    options: [
      {
        label: 'x64',
        extension: '.exe',
        href: `${releaseBaseUrl}/Yomitomo-${releaseVersion}-win-x64.exe`,
      },
    ],
  },
];

const downloadUrls = downloadPlatforms.flatMap((platform) =>
  platform.options.map((option) => option.href),
);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'Yomitomo',
      url: canonicalUrl,
      logo: `${siteUrl}/assets/yomitomo-logo.webp`,
      sameAs: [githubUrl, youtubeUrl],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'Yomitomo',
      url: canonicalUrl,
      inLanguage: 'zh-CN',
      publisher: {
        '@id': `${siteUrl}/#organization`,
      },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${siteUrl}/#software`,
      name: 'Yomitomo',
      description: pageDescription,
      url: canonicalUrl,
      image: ogImageUrl,
      applicationCategory: 'ProductivityApplication',
      operatingSystem: ['macOS', 'Windows'],
      softwareVersion: releaseVersion,
      downloadUrl: downloadUrls,
      codeRepository: githubUrl,
      license: `${githubUrl}/blob/main/LICENSE`,
      publisher: {
        '@id': `${siteUrl}/#organization`,
      },
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    },
  ],
};

const whyItems = [
  {
    number: '01',
    title: '现状问题',
    body: '大多数工具围绕“文章”这个粒度运转：收藏一篇、总结一篇、问答一篇。但你真正在意的不是文章本身，是你在某段话停下来时产生的那个想法。',
  },
  {
    number: '02',
    title: '想法没有好的归宿',
    body: '笔记软件里它脱离了原文，AI 摘要里它被替代了，稍后读里它还没来得及产生。',
  },
  {
    number: '03',
    title: 'Yomitomo 的做法',
    body: '把划线变成证据锚点，把想法变成阅读的最小单位。一条划线下面可以挂多个想法，每个想法可以继续讨论、追问、审阅。读完之后留下的不是脱离原文的摘要，而是一组能回到原文现场的阅读判断。',
  },
];

const comparisonItems = [
  {
    number: '01',
    title: '收藏 / 稍后读工具',
    judgment: '解决“先存着”，不解决“怎么读进去”。',
    features: ['收藏路径顺滑，囤积成本低', '发现内容快，启动阅读慢'],
    caveats: ['文章越存越多，真正产生的判断很少', '存下来的是文章，不是你的思考'],
  },
  {
    number: '02',
    title: '传统阅读器 / 笔记工具',
    judgment: '有划线有笔记，但划线只是静态标记。',
    features: ['阅读界面干净，标注功能有', '笔记可以导出，数据在自己手里'],
    caveats: ['一条划线只能挂一条笔记，不能自然承载讨论', '想法写完就是终态，没有继续推进的路径'],
  },
  {
    number: '03',
    title: 'Yomitomo',
    judgment: '以划线为证据锚点，以想法为阅读单位，按需让助手参与。',
    features: [
      '划线是原文锚点，一条划线下可以有多个想法',
      '每个想法可以继续评论，形成讨论线程',
      '用户决定哪个想法要请阅读助手参与讨论，或请审阅助手检查逻辑',
      '可以启动编排助手批量阅读，命中相同原文时自动合并到同一划线下',
      '读完留下的是能回到原文位置的判断，不是脱离上下文的摘要',
    ],
    caveats: [],
    highlight: true,
  },
];

const productSlides: ProductCarouselSlide[] = [
  {
    title: '沉淀阅读判断',
    caption: '把文章里的关键判断沉淀成想法，再交给阅读助手审阅和讨论。',
    image: '/assets/carousel/read-distil.webp',
    alt: 'Yomitomo 沉淀阅读判断界面',
  },
  {
    title: 'PDF 阅读库',
    caption: '论文和 PDF 按阅读进度、批注和讨论集中管理。',
    image: '/assets/carousel/pdf-list.webp',
    alt: 'Yomitomo PDF 阅读库界面',
  },
  {
    title: '电子书阅读库',
    caption: '电子书条目和阅读沉淀并列展示，长书也能持续积累。',
    image: '/assets/carousel/epub-list.webp',
    alt: 'Yomitomo 电子书阅读库界面',
  },
  {
    title: '微信读书同步',
    caption: '同步微信读书内容，把外部阅读也纳入同一套沉淀流程。',
    image: '/assets/carousel/weread-list.webp',
    alt: 'Yomitomo 微信读书列表界面',
  },
  {
    title: '网页文章阅读库',
    caption: '集中保存文章、批注和讨论，把阅读进度留在本机。',
    image: '/assets/carousel/web-page-list.webp',
    alt: 'Yomitomo 网页文章阅读库界面',
  },
  {
    title: '原文旁批注',
    caption: '划线保留证据位置，想法卡片持续挂在原文旁边。',
    image: '/assets/carousel/read-ann.webp',
    alt: 'Yomitomo 阅读批注界面',
  },
  {
    title: '批注讨论',
    caption: '围绕一条划线继续讨论，让想法从记录走向判断。',
    image: '/assets/carousel/read-discussion.webp',
    alt: 'Yomitomo 批注讨论界面',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="64x64" href="/assets/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="Yomitomo" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Yomitomo 产品界面预览" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Yomitomo 产品界面预览" />
    <meta name="theme-color" content="#f7f6f4" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="5dbd6cbd-a95b-401c-9a9d-40b237b6e4fa"
    ></script>
  </head>
  <body class="bg-page text-ink">
    <header class="site-header">
      <SiteHeader />
    </header>

    <main>
      <section class="hero">
        <div class="page-container min-w-0">
          <div class="hero-inner">
            <h1 class="hero-headline">
              <span>收藏了 500 篇文章，</span>
              <span class="hero-headline-line">真正留下来的<mark>判断</mark>有几个？</span>
            </h1>
            <p class="hero-sub">
              Yomitomo 把阅读的最小单位从文章变成判断——划线是证据锚点，想法是阅读产出。
            </p>
            <div id="install" class="install-panel" aria-labelledby="install-title">
              <div>
                <p class="install-version" aria-label={`当前版本 ${releaseTag}`}>
                  <span class="version-pulse" aria-hidden="true"></span>
                  <span>{releaseTag}</span>
                </p>
                <h2 id="install-title" class="install-title">下载 Yomitomo</h2>
              </div>
              <div class="download-cards">
                {
                  downloadPlatforms.map((platform) => (
                    <article class="download-card" data-platform={platform.platform}>
                      <div class="download-card-heading">
                        {platform.platform === 'mac' ? (
                          <svg
                            class="download-platform-icon"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                          >
                            <path
                              fill="currentColor"
                              d="M16.7 12.7c0-2.7 2.2-4 2.3-4.1-1.2-1.8-3.2-2.1-3.9-2.1-1.7-.2-3.2 1-4.1 1-.8 0-2.1-1-3.5-1-1.8 0-3.5 1.1-4.4 2.7-1.9 3.4-.5 8.4 1.4 11.1.9 1.3 2 2.8 3.5 2.8 1.4-.1 1.9-.9 3.5-.9s2.1.9 3.6.9c1.5 0 2.4-1.4 3.3-2.7 1-1.5 1.5-3 1.5-3.1 0-.1-3.1-1.3-3.2-4.6ZM14 4.7c.8-1 1.3-2.3 1.1-3.7-1.1 0-2.5.8-3.3 1.7-.7.9-1.3 2.2-1.2 3.5 1.3.1 2.6-.6 3.4-1.5Z"
                            ></path>
                          </svg>
                        ) : (
                          <svg
                            class="download-platform-icon"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                          >
                            <path
                              fill="currentColor"
                              d="M1.8 4.2 10.8 3v8.5h-9V4.2Zm10.4-1.4 10-1.4v10.1h-10V2.8ZM1.8 12.5h9V21l-9-1.2v-7.3Zm10.4 0h10v10.1l-10-1.4v-8.7Z"
                            ></path>
                          </svg>
                        )}
                        <h3>{platform.name}</h3>
                      </div>
                      <div class="download-options">
                        {platform.options.map((option) => (
                          <a
                            class="download-option"
                            href={option.href}
                            aria-label={`下载 Yomitomo ${platform.name} ${option.label} ${releaseTag}`}
                          >
                            <span>{option.label}</span>
                            <span class="download-option-meta">
                              <span>{option.extension}</span>
                              <svg
                                class="download-option-icon"
                                viewBox="0 0 24 24"
                                aria-hidden="true"
                              >
                                <path d="M12 15V3"></path>
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <path d="m7 10 5 5 5-5"></path>
                              </svg>
                            </span>
                          </a>
                        ))}
                      </div>
                      <span class="download-match">匹配当前系统</span>
                    </article>
                  ))
                }
              </div>
            </div>
            <ProductCarousel slides={productSlides} />
          </div>
        </div>
      </section>

      <hr class="m-0 border-0 border-t border-line" />

      <section class="section-block why-section">
        <div class="page-container">
          <p class="section-label">为什么需要 Yomitomo</p>
          <hr class="section-rule" />
          <h2 class="section-headline">你的阅读不是以文章为单位发生的，而是以一次次停顿发生的。</h2>

          <div class="why-list flex max-w-[860px] flex-col gap-[clamp(36px,5vh,56px)]">
            {
              whyItems.map((item) => (
                <article>
                  <span class="mb-2 block font-mono text-xs tracking-normal text-muted">
                    {item.number}
                  </span>
                  <h3 class="mb-2.5 mt-0 font-serif text-[clamp(17px,1.4vw,21px)] font-bold leading-[1.4] tracking-normal">
                    {item.title}
                  </h3>
                  <p class="m-0 leading-[1.85]">{item.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <hr class="m-0 border-0 border-t border-line" />

      <section id="comparison" class="section-block">
        <div class="page-container">
          <p class="section-label">场景对比</p>
          <hr class="section-rule" />
          <h2 class="section-headline">不是读得更快，是让每次停顿都留下东西。</h2>

          <div class="grid border border-line md:grid-cols-2 lg:grid-cols-3">
            {
              comparisonItems.map((item) => (
                <article
                  class:list={[
                    'relative p-[clamp(24px,3vw,40px)] md:[&:nth-child(3)]:col-span-2 md:[&:nth-child(3)]:border-t lg:[&:nth-child(3)]:col-span-1 lg:[&:nth-child(3)]:border-t-0',
                    'border-t border-line first:border-t-0 md:border-l md:first:border-l-0 md:[&:nth-child(2)]:border-t-0 lg:[&:nth-child(3)]:border-l',
                    item.highlight &&
                      'bg-accent-soft before:absolute before:-left-px before:-right-px before:-top-px before:h-[3px] before:bg-accent',
                  ]}
                >
                  <span class="mb-3.5 block font-mono text-xs tracking-normal text-muted">
                    {item.number}
                  </span>
                  <h3 class="mb-2 mt-0 font-serif text-[clamp(16px,1.2vw,19px)] font-bold leading-[1.35] tracking-normal">
                    {item.title}
                  </h3>
                  <p class="mb-[clamp(20px,3vh,32px)] mt-0 font-mono text-[0.78rem] leading-[1.65] text-muted">
                    {item.judgment}
                  </p>
                  <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
                    {
                      item.features.map((feature) => (
                        <li class="relative pl-[1.2em] text-[0.9rem] leading-[1.65] before:absolute before:left-0 before:font-bold before:content-['·']">
                          {feature}
                        </li>
                      ))
                    }
                    {
                      item.caveats.map((caveat) => (
                        <li class="relative pl-[1.2em] text-[0.9rem] leading-[1.65] text-muted before:absolute before:left-0 before:top-[0.15em] before:text-[0.75em] before:text-accent before:opacity-70 before:content-['※']">
                          {caveat}
                        </li>
                      ))
                    }
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <hr class="m-0 border-0 border-t border-line" />

    <SiteFooter />
    <script is:inline>
      const platform = navigator.userAgentData?.platform || navigator.platform || '';
      const os = /Win/i.test(platform) ? 'windows' : /Mac/i.test(platform) ? 'mac' : 'unknown';
      document.documentElement.dataset.platform = os;
    </script>
  </body>
</html>
