{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-await-in-loop": "off",
    "typescript/consistent-return": "off",
    "typescript/no-unsafe-type-assertion": "off"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.wxt/**",
    "**/.vite/**",
    "**/.cache/**",
    "**/.temp/**",
    "**/dist/**",
    "**/out/**",
    "**/build/**",
    "**/coverage/**",
    "**/vendor/foliate-js/**",
    "public/scripts/**"
  ]
}
